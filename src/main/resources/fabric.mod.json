{
	"schemaVersion": 1,
	"id": "archivist",
	"version": "${version}",
	"name": "Archivist",
	"description": "Automatically logs server plugins, brand, world info, and addresses on join.",
	"authors": [
		"apple"
	],
	"license": "MIT",
	"environment": "client",
	"entrypoints": {
		"client": [
			"com.archivist.ArchivistMod"
		],
		"meteor": [
			"com.archivist.meteor.ArchivistMeteorAddon"
		]
	},
	"mixins": [
		{
			"config": "archivist.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=${deps_fabric_loader}",
		"fabric-api": "*",
		"minecraft": "${minecraft_dep}",
		"java": ">=21"
	},
	"suggests": {
		"meteor-client": "*"
	},
	"custom": {
		"meteor-client:color": "89,78,255"
	},
	"modmenu": {
		"parent": {
			"id": "meteor-client"
		}
	}
}
